{% extends 'base.html.twig' %}
{% import "macro/event.macro.twig" as eventMacro %}

{% block body %}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mt-3 flex flex-col justify-center gap-4 md:flex-row">
        <div class="w-full md:w-1/3">
            {{ eventMacro.card(event) }}
        </div>
        <div class="w-full md:w-1/2">

            <div class="mb-3 divide-y divide-gray-200 rounded-lg border border-gray-200">
                <a href="{{ path('invite_event_organiser', {id: event.id}) }}"
                   class="flex items-center justify-between px-4 py-3 text-gray-900 no-underline hover:bg-gray-50">
                    <div>{{ 'add-event-organisers'|trans }}</div>
                    <div class="bi bi-plus-circle text-xl"></div>
                </a>
            </div>

            <div class="mb-3 rounded-lg border border-gray-200 bg-white shadow-sm">
                <div class="divide-y divide-gray-200">
                    <div class="px-4 py-3">
                        {{ 'event-organisers'|trans|title }}
                    </div>
                    {% for participant in event.organisers %}
                        <div class="px-4 py-3">
                            <div class="flex items-start justify-between">
                                <div class="flex items-start justify-start">
                                    <div>
                                        <div class="mb-3 flex">
                                            <img height="50" class="me-3" src="{{ participant.owner.avatar }}"/>
                                            <div>
                                                <div class="mb-1 font-bold">{{ participant.owner.fullName }}</div>
                                                <div class="mb-2 inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-800">{{ participant.role.value|trans }}</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div>
                                    <a href="{{ path('remove_event_organiser', {event: participant.event.id, id: participant.id}) }}">
                                        <span class="bi bi-x-circle text-2xl text-red-600"></span>
                                    </a>
                                </div>
                            </div>
                            <div class="text-center text-sm text-gray-500"> {{ participant.createdAt.diffForHumans }}</div>
                        </div>
                    {% endfor %}
                </div>
            </div>

            <div class="rounded-lg border border-gray-200 bg-white shadow-sm">
                <div class="divide-y divide-gray-200">
                    <div class="divide-y divide-gray-200">
                        <div class="px-4 py-3">
                            {{ 'sent-event-organiser-inviations'|trans|title }}
                        </div>
                        {% for inviation in event.eventOrganiserInvitations %}
                            <div class="px-4 py-3">
                                <div class="flex items-start justify-between">
                                    <div class="flex items-start justify-start">
                                        <div>
                                            <div class="mb-3 flex">
                                                <img height="50" class="me-3" src="{{ inviation.owner.avatar }}"/>
                                                <div>
                                                    <div class="mb-1 font-bold">{{ inviation.owner.fullName }}</div>
                                                    <div class="mb-1 inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-800">{{ inviation.role.value|trans }}</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div>
                                        <a href="#">
                                            <span class="bi bi-x-circle text-2xl text-red-600"></span>
                                        </a>
                                    </div>
                                </div>
                                <div class="text-center text-sm text-gray-500"> {{ inviation.createdAt.diffForHumans }}</div>
                            </div>

                        {% endfor %}
                    </div>
                </div>

            </div>
        </div>
    </div>
{% endblock %}
