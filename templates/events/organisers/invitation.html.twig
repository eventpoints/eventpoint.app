{% extends 'base.html.twig' %}
{% import "macro/event.macro.twig" as eventMacro %}

{% block body %}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mt-3 flex flex-col justify-center gap-4 md:flex-row">
            <div class="w-full md:w-1/3">
                {{ eventMacro.card(event) }}
            </div>
            <div class="w-full md:w-2/3">
                <div class="text-end text-xl">{{ 'invite-event-organiser'|trans }}</div>
                <hr class="border-gray-200"/>
                {{ form_start(eventOrganiserInvitationForm) }}
                <div class="rounded-lg border border-gray-200 bg-white shadow-sm">
                    <div class="p-4">
                        {{ form_row(eventOrganiserInvitationForm.owner) }}
                        {{ form_row(eventOrganiserInvitationForm.role) }}
                    </div>
                    <div class="border-t border-gray-200 px-4 py-3 text-end">
                        <button type="submit" class="rounded-lg bg-blue-700 px-5 py-2.5 text-sm font-medium text-white hover:bg-blue-800">{{ 'invite'|trans }}</button>
                    </div>
                </div>
                {{ form_end(eventOrganiserInvitationForm) }}
            </div>
        </div>
    </div>
{% endblock %}
