{% extends 'base.html.twig' %}
{% import "macro/event.macro.twig" as eventSettingsMacro %}

{% block body %}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mt-3 flex flex-col justify-center gap-4 md:flex-row">

            <div class="w-full md:w-1/3">

                <div class="mb-3 rounded-lg border border-gray-200 bg-white shadow-sm">
                    {% if event.base64Image %}
                        <img src="{{ event.base64Image }}"
                             class="{{ event.eventGroup == null ? 'rounded-t-lg w-full' : '' }} object-cover"
                             height="150px"
                             alt="{{ event.title }}">
                    {% endif %}
                    <div class="divide-y divide-gray-200">
                        <a href="{{ path('show_event', {id: event.id}) }}"
                           class="block px-4 py-3 text-gray-900 no-underline hover:bg-gray-50">
                            <div class="font-bold">{{ event.title }}</div>
                        </a>
                        {% if event.eventGroup %}
                            <a href="{{ path('event_group_show', {id: event.eventGroup.id}) }}"
                               class="flex items-center justify-between px-4 py-3 text-gray-900 no-underline hover:bg-gray-50">
                                <div class="bi bi-people-fill text-xl leading-none"></div>
                                <div class="font-bold">{{ event.eventGroup.name }}</div>
                            </a>
                        {% endif %}
                        <div class="flex items-center justify-start px-4 py-3">
                            <div class="me-2">{{ event.startAt|format_date(timezone=regional.timezone,pattern=day_date_pattern) }} </div>
                            <div>{{ event.startAt|format_time(timezone=regional.timezone,pattern=time_pattern) }}
                                - {{ event.endAt|format_time(timezone=regional.timezone,pattern=time_pattern) }}</div>
                        </div>
                        <div class="flex items-center justify-between px-4 py-3"
                                {{ stimulus_controller('clipboard', {
                                    successContent: "<span class='bi bi-check-lg text-green-600 text-xl'></span>"
                                }) }}
                        >
                            <div class="w-3/4"
                                 value="{{ event.address }}" {{ stimulus_target('clipboard', 'source') }} >{{ event.address }}</div>
                            <a class="me-2"
                               href="#" {{ stimulus_action('clipboard', 'copy', 'click') }} {{ stimulus_target('clipboard', 'button') }} >
                                <span class="bi bi-copy text-xl"></span>
                            </a>
                            <div class="relative">
                                <a class="text-blue-700 cursor-pointer" data-dropdown-toggle="mapAppChooserSettings">
                                    <i class="bi bi-map text-xl"></i>
                                </a>
                                <div id="mapAppChooserSettings" class="z-10 hidden w-44 divide-y divide-gray-100 rounded-lg bg-white shadow">
                                    <ul class="py-2 text-sm text-gray-700">
                                        <li><a class="block px-4 py-2 hover:bg-gray-100"
                                               href="https://www.google.com/maps?q={{ event.address }}" target="_blank">Open
                                                in Google Maps</a></li>
                                        <li><a class="block px-4 py-2 hover:bg-gray-100"
                                               href="http://maps.apple.com/?q={{ event.address }}" target="_blank">Open in
                                                Apple Maps</a></li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <div {{ stimulus_controller('read-more', {
                            moreText: 'read-more'|trans,
                            lessText: 'read-less'|trans,
                        }) }} class="px-4 py-3">
                            <div class="read-more-content" {{ stimulus_target('read-more', 'content') }}>{{ event.description|nl2br }}</div>
                            <a class="mt-2 block text-center text-gray-900" {{ stimulus_action('read-more', 'toggle', 'click') }} >{{ 'read-more'|trans }}</a>
                        </div>
                    </div>
                </div>


            </div>
            <div class="w-full md:w-1/2">

                <div class="divide-y divide-gray-200 rounded-lg border border-gray-200">
                    <a class="flex items-center justify-between px-4 py-3 text-gray-900 no-underline hover:bg-gray-50"
                       href="{{ path('edit_event', {id: event.id}) }}">
                        <div>{{ 'edit-event'|trans }}</div>
                        <div class="bi bi-pencil-fill text-xl"></div>
                    </a>
                    <a class="{{ app.request.attributes.get('_route') == 'manage_event_organisers' ? 'bg-blue-50 text-blue-700 font-semibold' : '' }} flex items-center justify-between px-4 py-3 text-gray-900 no-underline hover:bg-gray-50"
                       href="{{ path('event_tickets', {id: event.id}) }}">
                        <div>{{ 'manage-ticketing'|trans }}</div>
                        <div class="bi bi-ticket-fill text-xl"></div>
                    </a>
                    <a class="{{ app.request.attributes.get('_route') == 'manage_event_organisers' ? 'bg-blue-50 text-blue-700 font-semibold' : '' }} flex items-center justify-between px-4 py-3 text-gray-900 no-underline hover:bg-gray-50"
                       href="{{ path('manage_event_organisers', {id: event.id}) }}">
                        <div>{{ 'manage-event-orgnisers'|trans }}</div>
                        <div class="bi bi-people-fill text-xl"></div>
                    </a>
                    <a class="{{ app.request.attributes.get('_route') == 'cancel_event' ? 'bg-blue-50 text-blue-700 font-semibold' : '' }} flex items-center justify-between px-4 py-3 text-red-600 no-underline hover:bg-gray-50"
                       href="{{ path('cancel_event', {id: event.id}) }}">
                        <div>{{ 'cancel-event'|trans }}</div>
                        <div class="bi bi-exclamation-triangle-fill text-xl"></div>
                    </a>
                </div>

            </div>
        </div>
    </div>
{% endblock %}
