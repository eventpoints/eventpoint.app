{% extends 'base.html.twig' %}

{% block body %}

    {% if not event.isComplete %}
        <div {{ stimulus_controller('static-map', {
            token: mapbox_token,
            longitude: event.longitude,
            latitude: event.latitude,
            interactive: true,
        }) }}>
            <div class="static-map w-full" style="height: 220px" {{ stimulus_target('static-map', 'map') }}></div>
        </div>
    {% endif %}

    <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <div class="flex flex-col gap-8 lg:flex-row">
            {# Left sidebar #}
            <div class="w-full lg:w-96">
                {% if app.user and app.user|has_event_permission(event, 'role.event.organiser') or app.user and app.user|has_event_permission(event, 'role.event.promoter') %}
                    <div class="mb-4">
                        <a class="flex w-full items-center justify-center gap-2 rounded-xl border border-gray-200 bg-white px-4 py-3 text-sm font-medium text-gray-700 no-underline transition-colors hover:bg-gray-50 cursor-pointer"
                           data-modal-target="invitations"
                           data-modal-toggle="invitations">
                            {{ ux_icon('mdi:email-plus-outline', {class: 'text-lg text-gray-400'}) }}
                            <span>{{ 'send-inviations'|trans }}</span>
                        </a>
                    </div>
                {% endif %}

                <div class="overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-gray-100">
                    {% if event.isInProgress(regional.timezone) or event.eventCancellation or event.isComplete %}
                        {% if event.isInProgress(regional.timezone) %}
                            <div class="flex items-center justify-between border-b border-gray-100 bg-green-50 px-5 py-3">
                                <span class="text-sm font-medium text-green-700">{{ 'event-in-progress'|trans }}</span>
                                <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-1 text-xs font-medium text-green-700" {{ stimulus_controller('countdown', {
                                    milliseconds: event.timeRemainingInMilliseconds
                                }) }} {{ stimulus_target('countdown', 'result') }}></span>
                            </div>
                        {% endif %}
                        {% if event.isComplete %}
                            <div class="flex items-center justify-between border-b border-gray-100 bg-gray-50 px-5 py-3">
                                <span class="text-sm font-medium text-gray-600">{{ 'event-complete'|trans }}</span>
                                <span class="bi bi-check2-circle text-green-600"></span>
                            </div>
                        {% endif %}
                    {% endif %}

                    {% if event.base64Image %}
                        <img src="{{ event.base64Image }}"
                             class="h-48 w-full object-cover"
                             alt="{{ event.title }}">
                    {% endif %}

                    {# Stats row #}
                    <div class="grid grid-cols-3 divide-x divide-gray-100 border-b border-gray-100">
                        <a class="cursor-pointer py-4 text-center transition-colors hover:bg-gray-50"
                           data-modal-target="going" data-modal-toggle="going">
                            <div class="text-xl font-semibold text-gray-900">{{ event.allParticipantsCount|compact_notation }}</div>
                            <div class="text-xs font-medium uppercase tracking-wider text-gray-500">{{ 'going'|trans }}</div>
                        </a>
                        <a class="cursor-pointer py-4 text-center transition-colors hover:bg-gray-50"
                           data-modal-target="invited" data-modal-toggle="invited">
                            <div class="text-xl font-semibold text-gray-900">{{ event.allInvitationsCount|compact_notation }}</div>
                            <div class="text-xs font-medium uppercase tracking-wider text-gray-500">{{ 'invited'|trans }}</div>
                        </a>
                        <a class="cursor-pointer py-4 text-center transition-colors hover:bg-gray-50"
                           data-modal-target="requests" data-modal-toggle="requests">
                            <div class="text-xl font-semibold text-gray-900">{{ event.pendingRequests.count|compact_notation }}</div>
                            <div class="text-xs font-medium uppercase tracking-wider text-gray-500">{{ 'requested'|trans }}</div>
                        </a>
                    </div>

                    <div class="divide-y divide-gray-100">
                        <div class="px-5 py-4">
                            <h1 class="text-lg font-semibold text-gray-900">{{ event.title }}</h1>
                        </div>

                        {% if event.eventGroup %}
                            <a href="{{ path('event_group_show', {id: event.eventGroup.id}) }}"
                               class="flex items-center gap-3 px-5 py-4 text-gray-700 no-underline transition-colors hover:bg-gray-50">
                                {{ ux_icon('mdi:account-group-outline', {class: 'text-lg text-gray-400'}) }}
                                <span class="font-medium">{{ event.eventGroup.name }}</span>
                            </a>
                        {% endif %}

                        <div class="px-5 py-4">
                            {{ include('partials/event/_duration.html.twig') }}
                        </div>

                        <div class="flex items-center justify-between px-5 py-4"
                             {{ stimulus_controller('clipboard', {
                                 successContent: "<span class='bi bi-check-lg text-green-600'></span>"
                             }) }}>
                            <div class="flex-1 text-sm text-gray-600"
                                 value="{{ event.address }}" {{ stimulus_target('clipboard', 'source') }}>{{ event.address }}</div>
                            <div class="flex items-center gap-2">
                                <button class="inline-flex h-8 w-8 items-center justify-center rounded-full text-gray-400 transition-colors hover:bg-gray-100 hover:text-gray-600"
                                        {{ stimulus_action('clipboard', 'copy', 'click') }} {{ stimulus_target('clipboard', 'button') }}>
                                    <span class="bi bi-copy"></span>
                                </button>
                                <div class="relative">
                                    <button class="inline-flex h-8 w-8 items-center justify-center rounded-full text-gray-400 transition-colors hover:bg-gray-100 hover:text-gray-600"
                                            data-dropdown-toggle="mapAppChooser">
                                        <i class="bi bi-map"></i>
                                    </button>
                                    <div id="mapAppChooser" class="z-10 hidden w-48 overflow-hidden rounded-xl bg-white shadow-lg ring-1 ring-gray-100">
                                        <ul class="py-1">
                                            <li><a class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50"
                                                   href="https://www.google.com/maps?q={{ event.address }}" target="_blank">Open in Google Maps</a></li>
                                            <li><a class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50"
                                                   href="http://maps.apple.com/?q={{ event.address }}" target="_blank">Open in Apple Maps</a></li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {% if not event.isPrivate %}
                            <div class="px-5 py-4">
                                <div class="space-y-2">
                                    {% for ticket in event.ticketOptions %}
                                        <div class="flex items-center justify-between">
                                            <span class="text-sm text-gray-600">{{ ticket.title|title }}</span>
                                            {% if ticket.currency %}
                                                <span class="text-sm font-medium text-gray-900">{{ ticket.price|format_currency(ticket.currency) }}</span>
                                            {% endif %}
                                        </div>
                                    {% else %}
                                        <div class="text-sm font-medium text-green-600">{{ 'free-admission'|trans }}</div>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}

                        <div {{ stimulus_controller('read-more', {
                            moreText: 'read-more'|trans,
                            lessText: 'read-less'|trans,
                        }) }} class="px-5 py-4">
                            <div class="read-more-content text-sm text-gray-600 leading-relaxed" {{ stimulus_target('read-more', 'content') }}>{{ event.description|nl2br }}</div>
                            <button class="mt-3 text-sm font-medium text-gray-900 hover:text-gray-600" {{ stimulus_action('read-more', 'toggle', 'click') }}>{{ 'read-more'|trans }}</button>
                        </div>

                        {% if event.eventCancellation == null %}
                            {% if app.user and event.owner == app.user or app.user and app.user|has_event_permission(event, 'role.event.organiser') %}
                                <a href="{{ path('event_settings', {id: event.id}) }}"
                                   class="flex items-center justify-between px-5 py-4 text-gray-700 no-underline transition-colors hover:bg-gray-50">
                                    <span>{{ 'event-settings'|trans }}</span>
                                    {{ ux_icon('mdi:cog-outline', {class: 'text-lg text-gray-400'}) }}
                                </a>
                            {% endif %}
                        {% endif %}
                    </div>
                </div>
            </div>

            {# Main content #}
            <div class="flex-1">
                {% if not app.user and invitation != null %}
                    <div class="mb-6 overflow-hidden rounded-2xl bg-white p-6 text-center shadow-sm ring-1 ring-gray-100">
                        <div class="mb-4 text-4xl">🎉</div>
                        <p class="mb-4 text-gray-600">{{ 'token-invitation-text'|trans({name: invitation.owner.fullName}) }}</p>
                        <a class="inline-flex rounded-lg bg-gray-900 px-6 py-3 text-sm font-medium text-white no-underline transition-colors hover:bg-gray-800"
                           href="{{ path('app_register') }}">{{ 'sign-up'|trans }}</a>
                    </div>
                {% endif %}

                {% if app.user and event.unansweredInvitation(app.user) %}
                    {% set invitation = event.unansweredInvitation(app.user) %}
                    <div class="mb-6">
                        {{ component('event_invitation_response_banner_form', {
                            eventInvitation: invitation
                        }) }}
                    </div>
                {% endif %}

                {% if app.user and not event.hasRated(app.user) and event.isComplete %}
                    <div class="mb-6">
                        {{ component('event_rating_form_component', {event: event}) }}
                    </div>
                {% endif %}

                {{ include('partials/event/_image-upload.html.twig') }}

                {# Timeline #}
                <div class="mt-6">
                    <ol class="relative border-s border-gray-200">
                        {% for moment in event.eventMoments %}
                            {% if moment.type.name == 'EVENT_CANCELED' and event.eventCancellation %}
                                <li class="mb-10 ms-6">
                                    <span class="absolute flex items-center justify-center w-8 h-8 rounded-full -start-4 ring-8 ring-red-50 bg-red-100">
                                        <span class="bi bi-exclamation-triangle-fill text-red-500"></span>
                                    </span>
                                    <div class="p-4 bg-red-50 border border-red-100 rounded-lg shadow-sm">
                                        <div class="flex items-center justify-between mb-2">
                                            <time class="text-xs font-medium text-red-600">{{ moment.createdAt.diffForHumans }}</time>
                                        </div>
                                        <h3 class="text-sm font-semibold text-red-900">{{ moment.type.value|trans|title }}</h3>
                                        <p class="text-sm text-red-700">{{ event.eventCancellation.reason.value|trans|title }}</p>
                                        <div class="flex items-start gap-3 mt-3 pt-3 border-t border-red-100">
                                            <img src="{{ event.eventCancellation.owner.avatar }}" class="w-8 h-8 rounded-full object-cover" alt="">
                                            <div>
                                                <div class="text-sm font-medium text-gray-900">{{ event.eventCancellation.owner.fullName }}</div>
                                                <p class="text-xs text-gray-600">{{ event.eventCancellation.notice|nl2br }}</p>
                                            </div>
                                        </div>
                                    </div>
                                </li>
                            {% else %}
                                <li class="mb-6 ms-6">
                                    <span class="absolute flex items-center justify-center w-6 h-6 rounded-full -start-3 ring-8 ring-white {{ loop.first ? 'bg-gray-900' : 'bg-gray-200' }}">
                                        <span class="bi bi-bell-fill text-xs {{ loop.first ? 'text-white' : 'text-gray-500' }}"></span>
                                    </span>
                                    <div class="p-4 bg-white border border-gray-100 rounded-lg shadow-sm">
                                        <time class="mb-1 text-xs font-medium text-gray-400 sm:order-last">{{ moment.createdAt.diffForHumans }}</time>
                                        <p class="text-sm text-gray-600">{{ moment.type.value|trans({new: moment.newValue })|format|raw }}</p>
                                    </div>
                                </li>
                            {% endif %}
                        {% endfor %}

                        <li class="ms-6">
                            <span class="absolute flex items-center justify-center w-6 h-6 rounded-full -start-3 ring-8 ring-white bg-gray-100">
                                <span class="bi bi-check-circle text-xs text-gray-500"></span>
                            </span>
                            <div class="p-4 bg-gray-50 border border-gray-100 rounded-lg shadow-sm">
                                <time class="mb-1 text-xs font-medium text-gray-400 sm:order-last">{{ event.createdAt.diffForHumans }}</time>
                                <div class="flex items-center gap-3">
                                    <img src="{{ event.owner.avatar }}" class="w-8 h-8 rounded-full object-cover" alt="">
                                    <p class="text-sm text-gray-600">{{ 'event-created-at'|trans({name: event.owner.firstName}) }}</p>
                                </div>
                            </div>
                        </li>
                    </ol>
                </div>
            </div>
        </div>
    </div>

    {# Invitations modal #}
    <div id="invitations" tabindex="-1" aria-hidden="true"
         class="fixed left-0 right-0 top-0 z-50 hidden h-[calc(100%-1rem)] max-h-full w-full overflow-y-auto overflow-x-hidden p-4 md:inset-0">
        <div class="relative max-h-full w-full max-w-md">
            <div class="relative flex max-h-[80vh] flex-col overflow-hidden rounded-2xl bg-white shadow-xl ring-1 ring-gray-100">
                <div class="flex items-center justify-between border-b border-gray-100 px-6 py-4">
                    <h2 class="text-base font-semibold text-gray-900">{{ 'send-invitations'|trans|capitalize }}</h2>
                    <button type="button" class="inline-flex h-8 w-8 items-center justify-center rounded-full text-gray-400 transition-colors hover:bg-gray-100 hover:text-gray-600" data-modal-hide="invitations">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 14 14"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/></svg>
                    </button>
                </div>
                {{ component('InvitationEmailAutocompleteComponent', {event: event}) }}
            </div>
        </div>
    </div>

    {# Going modal #}
    <div id="going" tabindex="-1" aria-hidden="true"
         class="fixed left-0 right-0 top-0 z-50 hidden h-[calc(100%-1rem)] max-h-full w-full overflow-y-auto overflow-x-hidden p-4 md:inset-0">
        <div class="relative max-h-full w-full max-w-md">
            <div class="relative overflow-hidden rounded-2xl bg-white shadow-xl ring-1 ring-gray-100">
                <div class="flex items-center justify-between border-b border-gray-100 px-6 py-4">
                    <h2 class="text-base font-semibold text-gray-900">{{ 'going'|trans|capitalize }}</h2>
                    <button type="button" class="inline-flex h-8 w-8 items-center justify-center rounded-full text-gray-400 transition-colors hover:bg-gray-100 hover:text-gray-600" data-modal-hide="going">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 14 14"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/></svg>
                    </button>
                </div>
                <div class="max-h-96 divide-y divide-gray-100 overflow-y-auto">
                    {% for participant in event.eventParticipants %}
                        <a href="{{ path('show_profile', {id: participant.owner.id}) }}"
                           class="flex items-center justify-between px-6 py-4 no-underline transition-colors hover:bg-gray-50">
                            <div class="flex items-center gap-3">
                                <img src="{{ participant.owner.avatar }}" class="h-10 w-10 rounded-full object-cover" alt="">
                                <div>
                                    <div class="font-medium text-gray-900">{{ participant.owner.fullName|title }}</div>
                                    <div class="text-xs text-gray-500">{{ participant.createdAt|time_ago }}</div>
                                </div>
                            </div>
                            <div class="flex gap-1">
                                {% if participant.owner == event.owner %}
                                    <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600">{{ 'creator'|trans }}</span>
                                {% endif %}
                                {% if participant.role.value != 'role.event.participant' %}
                                    <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600">{{ participant.role.value|trans }}</span>
                                {% endif %}
                            </div>
                        </a>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

    {# Invited modal #}
    <div id="invited" tabindex="-1" aria-hidden="true"
         class="fixed left-0 right-0 top-0 z-50 hidden h-[calc(100%-1rem)] max-h-full w-full overflow-y-auto overflow-x-hidden p-4 md:inset-0">
        <div class="relative max-h-full w-full max-w-md">
            <div class="relative overflow-hidden rounded-2xl bg-white shadow-xl ring-1 ring-gray-100">
                <div class="flex items-center justify-between border-b border-gray-100 px-6 py-4">
                    <h2 class="text-base font-semibold text-gray-900">{{ 'invited'|trans|capitalize }}</h2>
                    <button type="button" class="inline-flex h-8 w-8 items-center justify-center rounded-full text-gray-400 transition-colors hover:bg-gray-100 hover:text-gray-600" data-modal-hide="invited">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 14 14"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/></svg>
                    </button>
                </div>
                <div class="max-h-96 divide-y divide-gray-100 overflow-y-auto">
                    {% for invitation in invitations %}
                        <div class="flex items-center justify-between px-6 py-4">
                            {% if invitation.targetUser %}
                                <div class="flex items-center gap-3">
                                    <img src="{{ invitation.targetUser.avatar }}" class="h-10 w-10 rounded-full object-cover" alt="">
                                    <div>
                                        <div class="font-medium text-gray-900">{{ invitation.targetUser.fullName|title }}</div>
                                        <div class="text-xs text-gray-500">{{ invitation.createdAt|time_ago }}</div>
                                    </div>
                                </div>
                            {% elseif invitation.targetEmail %}
                                <div class="flex items-center gap-3">
                                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-gray-100">
                                        <span class="mdi mdi-at text-gray-500"></span>
                                    </div>
                                    <div>
                                        <div class="font-medium text-gray-900">{{ invitation.targetEmail.address }}</div>
                                        <div class="text-xs text-gray-500">{{ invitation.createdAt|time_ago }}</div>
                                    </div>
                                </div>
                            {% endif %}
                            {% if app.user and app.user|has_event_permission(event, 'role.event.organiser') %}
                                <a href="{{ path('remove_invitation', {id: invitation.id, token: csrf_token('remove-invitation')}) }}"
                                   class="inline-flex h-8 w-8 items-center justify-center rounded-full text-red-500 transition-colors hover:bg-red-50">
                                    <span class="bi bi-x-lg"></span>
                                </a>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
                {% if app.user and app.user|has_event_permission(event, 'role.event.organiser') or app.user and app.user|has_event_permission(event, 'role.event.promoter') %}
                    <div class="border-t border-gray-100 p-4">
                        <a class="flex w-full cursor-pointer items-center justify-center rounded-lg bg-gray-900 px-4 py-2.5 text-sm font-medium text-white transition-colors hover:bg-gray-800"
                           data-modal-hide="invited"
                           data-modal-target="invitations"
                           data-modal-toggle="invitations">
                            {{ 'send-inviations'|trans }}
                        </a>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    {# Requests modal #}
    <div id="requests" tabindex="-1" aria-hidden="true"
         class="fixed left-0 right-0 top-0 z-50 hidden h-[calc(100%-1rem)] max-h-full w-full overflow-y-auto overflow-x-hidden p-4 md:inset-0">
        <div class="relative max-h-full w-full max-w-md">
            <div class="relative overflow-hidden rounded-2xl bg-white shadow-xl ring-1 ring-gray-100">
                <div class="flex items-center justify-between border-b border-gray-100 px-6 py-4">
                    <h2 class="text-base font-semibold text-gray-900">{{ 'requested'|trans|capitalize }}</h2>
                    <button type="button" class="inline-flex h-8 w-8 items-center justify-center rounded-full text-gray-400 transition-colors hover:bg-gray-100 hover:text-gray-600" data-modal-hide="requests">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 14 14"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/></svg>
                    </button>
                </div>
                <div class="divide-y divide-gray-100">
                    {% if app.user and not event.isAttending(app.user) and not event.isOrganiser(app.user) %}
                        {% if not event.requestedToAttend(app.user) %}
                            <div class="p-6 text-center">
                                <p class="mb-4 text-sm text-gray-600">{{ 'request-explainer-text'|trans }}</p>
                                <a href="{{ path('event_rsvp_request', {id : event.id}) }}"
                                   class="inline-flex rounded-lg bg-gray-900 px-6 py-2.5 text-sm font-medium text-white transition-colors hover:bg-gray-800">{{ 'request-to-attend'|trans }}</a>
                            </div>
                        {% else %}
                            <div class="p-6 text-center">
                                <p class="mb-4 text-sm text-gray-600">{{ 'event-request-sent-explainer'|trans|capitalize }}</p>
                                <a href="{{ path('cancel_event_rsvp_request', {id : event.attendRequest(app.user).id}) }}"
                                   class="inline-flex rounded-lg border border-red-200 px-6 py-2.5 text-sm font-medium text-red-600 transition-colors hover:bg-red-50">{{ 'cancel-request'|trans }}</a>
                            </div>
                        {% endif %}
                    {% endif %}
                    {% if app.user and event.isOrganiser(app.user) %}
                        {% for request in event.pendingRequests %}
                            {{ component('EventRequestResponseFormComponent', {eventRequest: request}) }}
                        {% else %}
                            <div class="p-6 text-center text-sm text-gray-500">{{ 'no-requests'|trans }}</div>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

{% endblock %}
