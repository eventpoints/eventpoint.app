{% extends 'base.html.twig' %}

{% block title %}{{ event.title }}{% endblock %}

{% block body %}
    <div class="mx-auto max-w-lg px-4 py-16">

        {# Event header #}
        <div class="mb-8 overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-gray-100">
            {% if event.base64Image %}
                <img src="{{ event.base64Image }}" alt="{{ event.title }}"
                     class="h-40 w-full object-cover">
            {% endif %}

            <div class="p-6 text-center">
                <div class="mb-3 flex items-center justify-center">
                    <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-gray-100">
                        <i class="bi bi-lock-fill text-xl text-gray-500"></i>
                    </span>
                </div>
                <h1 class="text-xl font-semibold text-gray-900">{{ event.title }}</h1>
                <p class="mt-1 text-sm text-gray-500">
                    {{ event.startAt|format_date(timezone=regional.timezone, pattern=day_date_pattern) }}
                    · {{ event.startAt|format_time(timezone=regional.timezone, pattern=time_pattern) }}
                </p>
                <p class="mt-3 text-sm text-gray-500">{{ 'event.private.description'|trans }}</p>
            </div>
        </div>

        {# Invitation with no account — registration form #}
        {% if invitation != null and not app.user %}
            {% if invitationEmailHasAccount %}
                <div class="overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-gray-100">
                    <div class="p-6 text-center">
                        <p class="mb-1 text-sm font-medium text-gray-900">{{ 'token-invitation-text'|trans({name: invitation.owner.fullName}) }}</p>
                        <p class="mb-5 text-sm text-gray-500">{{ 'invitation-sign-in-prompt'|trans }}</p>
                        <a href="{{ path('app_login', {'_target_path': app.request.uri}) }}"
                           class="inline-flex w-full items-center justify-center rounded-lg bg-primary-600 px-4 py-2.5 text-sm font-medium text-white no-underline transition-colors hover:bg-primary-700">
                            {{ 'sign-in'|trans }}
                        </a>
                    </div>
                </div>
            {% elseif registrationForm is not null %}
                <div class="overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-gray-100">
                    <div class="border-b border-gray-100 p-6 text-center">
                        <p class="text-sm font-medium text-gray-900">{{ 'token-invitation-text'|trans({name: invitation.owner.fullName}) }}</p>
                        <p class="mt-1 text-sm text-gray-500">{{ 'event.private.sign-up-to-view'|trans }}</p>
                    </div>
                    <div class="p-6">
                        {{ form_errors(registrationForm) }}
                        {{ form_start(registrationForm) }}
                        <div class="space-y-3">
                            <div class="grid grid-cols-2 gap-3">
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-gray-700">{{ 'first-name'|trans }}</label>
                                    {{ form_widget(registrationForm.firstName, {attr: {class: 'block w-full rounded-lg border border-gray-200 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-gray-400 focus:bg-white focus:outline-none'}}) }}
                                </div>
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-gray-700">{{ 'last-name'|trans }}</label>
                                    {{ form_widget(registrationForm.lastName, {attr: {class: 'block w-full rounded-lg border border-gray-200 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-gray-400 focus:bg-white focus:outline-none'}}) }}
                                </div>
                            </div>
                            <div>
                                <label class="mb-1.5 block text-sm font-medium text-gray-700">{{ 'email'|trans }}</label>
                                {{ form_widget(registrationForm.email, {attr: {class: 'block w-full rounded-lg border border-gray-200 bg-gray-100 px-3 py-2.5 text-sm text-gray-500 focus:outline-none', readonly: 'readonly'}}) }}
                            </div>
                            <div>
                                <label class="mb-1.5 block text-sm font-medium text-gray-700">{{ 'password'|trans }}</label>
                                <div class="flex" {{ stimulus_controller('password-visibility') }}>
                                    {{ form_widget(registrationForm.plainPassword, {attr: {class: 'block w-full rounded-l-lg border border-r-0 border-gray-200 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-gray-400 focus:bg-white focus:outline-none'}}) }}
                                    <button type="button" data-action="password-visibility#toggle"
                                            class="inline-flex items-center rounded-r-lg border border-gray-200 bg-gray-50 px-3 text-gray-500 transition-colors hover:bg-gray-100">
                                        <span data-password-visibility-target="icon" class="bi bi-eye-fill"></span>
                                        <span data-password-visibility-target="icon" class="bi bi-eye-slash-fill hidden"></span>
                                    </button>
                                </div>
                            </div>
                            <button type="submit"
                                    class="w-full rounded-lg bg-primary-600 px-4 py-2.5 text-sm font-medium text-white transition-colors hover:bg-primary-700">
                                {{ 'create-account'|trans }}
                            </button>
                        </div>
                        {{ form_end(registrationForm) }}
                        <p class="mt-4 text-center text-sm text-gray-500">
                            {{ 'already-have-account'|trans }}
                            <a href="{{ path('app_login', {'_target_path': app.request.uri}) }}"
                               class="font-medium text-gray-900 no-underline hover:underline">{{ 'sign-in'|trans }}</a>
                        </p>
                    </div>
                </div>
            {% endif %}

        {# Logged in but no access #}
        {% elseif app.user %}
            <div class="rounded-2xl bg-white p-6 text-center shadow-sm ring-1 ring-gray-100">
                <p class="text-sm text-gray-500">{{ 'event.private.no-access'|trans }}</p>
            </div>

        {# Not logged in, no invitation token #}
        {% else %}
            <div class="rounded-2xl bg-white p-6 text-center shadow-sm ring-1 ring-gray-100">
                <p class="mb-4 text-sm text-gray-500">{{ 'event.private.sign-in-if-invited'|trans }}</p>
                <a href="{{ path('app_login', {'_target_path': app.request.uri}) }}"
                   class="inline-flex items-center justify-center rounded-lg bg-gray-900 px-5 py-2.5 text-sm font-medium text-white no-underline transition-colors hover:bg-gray-800">
                    {{ 'sign-in'|trans }}
                </a>
            </div>
        {% endif %}

    </div>
{% endblock %}
