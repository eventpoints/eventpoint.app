{% extends 'base.html.twig' %}
{% import "macro/event.macro.twig" as eventSettingsMacro %}

{% block body %}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mt-3 flex flex-col justify-center gap-4 md:flex-row">

            <div class="w-full md:w-1/3">
                <div class="mb-3 rounded-lg border border-gray-200 bg-white shadow-sm">
                    {% if event.base64Image %}
                        <img src="{{ event.base64Image }}"
                             class="{{ event.eventGroup == null ? 'rounded-t-lg w-full' : '' }} object-cover"
                             height="150px"
                             alt="{{ event.title }}">
                    {% endif %}
                    <div class="divide-y divide-gray-200">
                        <a href="{{ path('show_event', {id: event.id}) }}"
                           class="block px-4 py-3 text-gray-900 no-underline hover:bg-gray-50">
                            <div class="font-bold">{{ event.title }}</div>
                        </a>
                        {% if event.eventGroup %}
                            <a href="{{ path('event_group_show', {id: event.eventGroup.id}) }}"
                               class="flex items-center justify-between px-4 py-3 text-gray-900 no-underline hover:bg-gray-50">
                                <div class="bi bi-people-fill text-xl leading-none"></div>
                                <div class="font-bold">{{ event.eventGroup.name }}</div>
                            </a>
                        {% endif %}
                        <div class="flex items-center justify-start px-4 py-3">
                            <div class="me-2">{{ event.startAt|format_date(timezone=regional.timezone,pattern=day_date_pattern) }}</div>
                            <div>{{ event.startAt|format_time(timezone=regional.timezone,pattern=time_pattern) }}
                                - {{ event.endAt|format_time(timezone=regional.timezone,pattern=time_pattern) }}</div>
                        </div>
                        <div class="flex items-center justify-between px-4 py-3"
                             {{ stimulus_controller('clipboard', {
                                 successContent: "<span class='bi bi-check-lg text-green-600 text-xl'></span>"
                             }) }}>
                            <div class="w-3/4" value="{{ event.address }}" {{ stimulus_target('clipboard', 'source') }}>{{ event.address }}</div>
                            <a class="me-2" href="#"
                               {{ stimulus_action('clipboard', 'copy', 'click') }}
                               {{ stimulus_target('clipboard', 'button') }}>
                                <span class="bi bi-copy text-xl"></span>
                            </a>
                            <div class="relative">
                                <a class="cursor-pointer text-blue-700" data-dropdown-toggle="mapAppChooserTickets">
                                    <i class="bi bi-map text-xl"></i>
                                </a>
                                <div id="mapAppChooserTickets" class="z-10 hidden w-44 divide-y divide-gray-100 rounded-lg bg-white shadow">
                                    <ul class="py-2 text-sm text-gray-700">
                                        <li><a class="block px-4 py-2 hover:bg-gray-100"
                                               href="https://www.google.com/maps?q={{ event.address }}" target="_blank">Open in Google Maps</a></li>
                                        <li><a class="block px-4 py-2 hover:bg-gray-100"
                                               href="http://maps.apple.com/?q={{ event.address }}" target="_blank">Open in Apple Maps</a></li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                        <twig:ReadMore :content="event.description" wrapperClass="px-4 py-3" />
                    </div>
                </div>
            </div>

            <div class="w-full md:w-1/2">

                {% if merchantGateMissingSteps is not empty %}
                    <div class="mb-3 rounded-lg border border-gray-200 bg-gray-50 p-4">
                        <h5 class="mb-1 font-semibold">{{ 'ticketing.gate.setup_required'|trans }}</h5>
                        <p class="mb-3 text-sm">{{ 'ticketing.gate.setup_description'|trans }}</p>
                        <div class="flex flex-wrap justify-end gap-2">
                            {% if 'profile' in merchantGateMissingSteps %}
                                <a href="{{ path('merchant_profile', {event_id: event.id}) }}"
                                   class="rounded-lg bg-primary-600 px-5 py-3 text-sm font-medium text-white transition-colors hover:bg-primary-700">
                                    {{ 'ticketing.gate.complete_profile'|trans }}
                                </a>
                            {% endif %}
                            {% if 'stripe' in merchantGateMissingSteps and 'profile' not in merchantGateMissingSteps %}
                                <a href="{{ path('stripe_connect_start', {event_id: event.id}) }}"
                                   class="rounded-lg bg-primary-600 px-5 py-3 text-sm font-medium text-white transition-colors hover:bg-primary-700">
                                    {{ 'ticketing.gate.connect_stripe'|trans }}
                                </a>
                            {% endif %}
                        </div>
                    </div>
                {% else %}
                    <div class="mb-3 divide-y divide-gray-200 rounded-lg border border-gray-200">
                        <a class="w-full flex items-center justify-between px-4 py-3 text-gray-900 no-underline hover:bg-gray-50"
                           href="{{ path('create_event_ticket', {id: event.id}) }}">
                            <div>{{ 'add-ticket-option'|trans }}</div>
                            <div class="bi bi-plus-circle text-xl"></div>
                        </a>
                    </div>
                {% endif %}

                {% for ticketOption in event.ticketOptions %}
                    <div class="mb-3 rounded-lg border border-gray-200 bg-white shadow-sm {{ not ticketOption.isEnabled ? 'opacity-50' : '' }}">
                        <div class="flex items-center justify-between px-4 py-3">
                            <div>
                                <span class="font-semibold text-gray-900">{{ ticketOption.title }}</span>
                                {% if not ticketOption.isEnabled %}
                                    <span class="ml-2 inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600">
                                        {{ 'ticketing.ticket_option.disabled'|trans }}
                                    </span>
                                {% endif %}
                                <div class="text-sm text-gray-500">{{ ticketOption.price.baseUnit|format_currency(ticketOption.price.currency) }}</div>
                            </div>
                            <div class="flex items-center gap-2">
                                <form method="post" action="{{ path('toggle_event_ticket', {id: ticketOption.id}) }}">
                                    <button type="submit"
                                            class="rounded-lg border px-3 py-1.5 text-xs font-medium transition-colors {{ ticketOption.isEnabled ? 'border-gray-300 text-gray-700 hover:bg-gray-50' : 'border-green-200 text-green-700 hover:bg-green-50' }}">
                                        {{ ticketOption.isEnabled ? ('ticketing.ticket_option.disable'|trans) : ('ticketing.ticket_option.enable'|trans) }}
                                    </button>
                                </form>
                                <form method="post" action="{{ path('delete_event_ticket', {id: ticketOption.id}) }}"
                                      onsubmit="return confirm('{{ 'ticketing.ticket_option.delete_confirm'|trans }}')">
                                    <button type="submit"
                                            class="rounded-lg border border-red-200 px-3 py-1.5 text-xs font-medium text-red-600 transition-colors hover:bg-red-50">
                                        {{ 'ticketing.ticket_option.delete'|trans }}
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                {% endfor %}

            </div>
        </div>
    </div>
{% endblock %}
