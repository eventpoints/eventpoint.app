{% extends 'base.html.twig' %}

{% block body %}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mt-3 flex justify-center">
            <div class="w-full md:w-1/2">
                <div class="text-end text-2xl font-bold">{{ 'password-reset'|trans|upper }}</div>
                <hr class="mt-0 border-gray-200"/>
                {{ form_start(userPasswordForm) }}
                <div class="mb-5 rounded-lg border border-gray-200 bg-white shadow-sm">
                    <div class="divide-y divide-gray-200">
                        <div class="px-4 py-3">
                            {{ form_row(userPasswordForm.password) }}
                        </div>
                    </div>
                    <div class="flex justify-center border-t border-gray-200 px-4 py-3">
                        <button type="submit" class="w-full rounded-lg bg-blue-700 px-5 py-2.5 text-sm font-medium text-white hover:bg-blue-800">{{ 'save'|trans }}</button>
                    </div>
                </div>
                {{ form_end(userPasswordForm) }}
            </div>
        </div>
    </div>
{% endblock %}
