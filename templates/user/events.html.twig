{% extends 'base.html.twig' %}


{% block body %}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mt-3 flex flex-col justify-center gap-4 md:flex-row">
            <div class="w-full md:w-1/3">
                <div class="rounded-lg border border-gray-200 bg-white shadow-sm">
                    {{ include('partials/_account-navbar.html.twig') }}
                </div>
            </div>
            <div class="w-full md:w-1/2">
                <div class="text-end text-2xl font-bold">{{ 'your-events'|trans|upper }}</div>
                <hr class="my-4 border-gray-200"/>
                <div class="flex flex-col gap-4">
                    {% for event in events %}
                        <div class="w-full">
                            <twig:EventCard :event="event" />
                        </div>
                    {% else %}
                        <div class="px-4 py-3 text-center font-bold text-gray-500">{{ 'no-events-found'|trans|upper }}</div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
