{% extends 'base.html.twig' %}


{% block body %}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mt-3 flex flex-col justify-center gap-4 md:flex-row">
            <div class="w-full md:w-1/3">
                <div class="rounded-lg border border-gray-200 bg-white shadow-sm">
                    {{ include('partials/_account-navbar.html.twig') }}
                </div>
            </div>
            <div class="w-full md:w-1/2">
                <h2 class="mb-4 text-xl font-semibold text-gray-900">{{ 'your-events'|trans|capitalize }}</h2>
                <div class="flex flex-col gap-3">
                    {% for event in events %}
                        <div class="w-full">
                            <twig:EventCard :event="event" />
                        </div>
                    {% else %}
                        <div class="overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-gray-100">
                            <div class="flex flex-col items-center justify-center px-6 py-16 text-center">
                                {{ ux_icon('mdi:calendar-outline', {class: 'mx-auto mb-3 h-12 w-12 text-gray-200'}) }}
                                <p class="text-sm font-medium text-gray-500">{{ 'no-events-found'|trans }}</p>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
