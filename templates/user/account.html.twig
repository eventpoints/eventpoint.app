{% extends 'base.html.twig' %}

{% block body %}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mt-3 flex flex-col justify-center gap-4 md:flex-row">
            <div class="w-full md:w-1/3">
                <div class="rounded-lg border border-gray-200 bg-white shadow-sm">
                    {{ include('partials/_account-navbar.html.twig') }}
                </div>
            </div>
            <div class="w-full md:w-1/2">
                <h2 class="mb-6 text-xl font-semibold text-gray-900">{{ 'account'|trans|capitalize }}</h2>

                {{ form_start(userAccountForm) }}
                <div class="mb-5 overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
                    <div class="divide-y divide-gray-200">
                        <div class="px-4 py-3">
                            <div class="flex items-center justify-between gap-4">
                                <div class="flex-1">{{ form_row(userAccountForm.firstName) }}</div>
                                <div class="flex-1">{{ form_row(userAccountForm.lastName) }}</div>
                            </div>
                        </div>
                        <a href="{{ path('user_email_addresses') }}"
                           class="block px-4 py-3 text-gray-900 no-underline hover:bg-gray-50">
                            <div class="mb-3">{{ 'multiple-email-account-explainer'|trans }}</div>
                            <div class="mb-3 flex flex-wrap items-center justify-start gap-2">
                                {% for email in app.user.emails %}
                                    <div class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium {{ email == app.user.email ? 'bg-blue-100 text-blue-800' : 'bg-gray-100 text-gray-800' }}">{{ email.address }}</div>
                                {% endfor %}
                            </div>
                        </a>
                        <div class="flex items-start justify-between px-4 py-3">
                            {{ form_row(userAccountForm.avatarFile) }}
                            <img height="100" class="border border-gray-200 rounded" src="{{ user_avatar(app.user) }}"/>
                        </div>
                        <div class="px-4 py-3">
                            {{ form_row(userAccountForm.locale) }}
                        </div>
                        <div class="px-4 py-3">
                            {{ form_row(userAccountForm.timezone) }}
                        </div>
                        <div class="px-4 py-3">
                            {{ form_row(userAccountForm.currency) }}
                        </div>
                        <div class="px-4 py-3">
                            {{ form_row(userAccountForm.country) }}
                        </div>
                        <a href="{{ path('change_user_password') }}"
                           class="flex items-center justify-between px-4 py-3 text-gray-900 no-underline hover:bg-gray-50">
                            <div> {{ 'change-password'|trans|capitalize }}</div>
                            <div class="bi bi-key text-2xl"></div>
                        </a>
                    </div>
                    <div class="flex justify-center border-t border-gray-200 px-4 py-4">
                        <button type="submit" class="w-full rounded-lg bg-primary-600 px-4 py-2.5 text-center text-sm font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-4 focus:ring-primary-300">{{ 'save'|trans }}</button>
                    </div>
                </div>
                {{ form_end(userAccountForm) }}


            </div>
        </div>
    </div>
{% endblock %}