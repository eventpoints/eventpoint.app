{% extends 'base.html.twig' %}

{% block body %}
<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mt-3 flex flex-col justify-center gap-4 md:flex-row">

        {# --- Account sidebar --- #}
        <div class="w-full md:w-1/3">
            <div class="rounded-lg border border-gray-200 bg-white shadow-sm">
                {{ include('partials/_account-navbar.html.twig') }}
            </div>
        </div>

        {# --- Invitations list --- #}
        <div class="w-full md:w-1/2">
            <h1 class="mb-4 text-xl font-semibold text-gray-900">{{ 'invitations'|trans|capitalize }}</h1>

            <div class="flex flex-col gap-3">
                {% for invitation in eventInvitations %}
                    {{ include('components/event_invitation_response_form.html.twig', {
                        invitation: invitation
                    }) }}
                {% else %}
                    <div class="overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-gray-100">
                        <div class="flex flex-col items-center justify-center px-6 py-16 text-center">
                            {{ ux_icon('mdi:email-outline', {class: 'mx-auto mb-3 h-12 w-12 text-gray-200'}) }}
                            <p class="text-sm font-medium text-gray-500">{{ 'no-invitations-found'|trans }}</p>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>

    </div>
</div>
{% endblock %}
