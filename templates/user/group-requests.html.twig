{% extends 'base.html.twig' %}

{% block body %}
    <div class="container">
        <div class="row justify-content-center mt-3">
            <div class="col-12 col-md-4">
                <div class="card">
                    {{ include('partials/_account-navbar.html.twig') }}
                </div>
            </div>
            <div class="col-12 col-md-6">
                <h2 class="mb-6 text-xl font-semibold text-gray-900">{{ 'group-requests'|trans|capitalize }}</h2>
                <div class="card">
                    <div class="list-group list-group-flush">
                        {% for joinRequest in app.user.eventGroupJoinRequests %}
                            <a href="{{ path('event_group_show', {id: group.id }) }}"
                               class="list-group-item list-group-item-action d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="fw-bold">{{ joinRequest.eventGroup.name|title }}</div>
                                </div>
                                <div>
                                    <div class="badge rounded-pill text-bg-primary fs-5 d-flex justify-content-between align-items-center">
                                        <span class="bi bi-people me-3"></span>
                                        <span>{{ joinRequest.eventGroup.eventGroupMembers.count }}</span>
                                    </div>
                                </div>
                            </a>
                        {% else %}
                            <div class="list-group-item text-center fw-bold">{{ 'no-requests-found'|trans }}</div>
                        {% endfor %}
                    </div>
                </div>

            </div>
        </div>
    </div>
{% endblock %}