{% extends 'base.html.twig' %}

{% block body %}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mt-3 flex flex-col justify-center gap-4 md:flex-row">
            <div class="w-full md:w-1/3">
                <div class="rounded-lg border border-gray-200 bg-white shadow-sm">
                    {{ include('partials/_account-navbar.html.twig') }}
                </div>
            </div>
            <div class="w-full md:w-1/2">
                <h2 class="mb-6 text-xl font-semibold text-gray-900">{{ 'add-email-addresses'|trans|capitalize }}</h2>

                {{ form_start(emailForm) }}
                <div class="mb-4">
                    {{ form_row(emailForm.address) }}
                </div>
                <button type="submit" class="w-full rounded-lg bg-primary-600 px-4 py-2.5 text-center text-sm font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-4 focus:ring-primary-300">{{ 'save'|trans }}</button>
                {{ form_end(emailForm) }}

            </div>
        </div>
    </div>
{% endblock %}