{% extends 'base.html.twig' %}

{% block body %}
<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mt-3 flex flex-col justify-center gap-4 md:flex-row">

        {# --- Account sidebar --- #}
        <div class="w-full md:w-1/3">
            <div class="rounded-lg border border-gray-200 bg-white shadow-sm">
                {{ include('partials/_account-navbar.html.twig') }}
            </div>
        </div>

        {# --- Conversations list --- #}
        <div class="w-full md:w-1/2">
            <h1 class="mb-4 text-xl font-semibold text-gray-900">{{ 'conversations'|trans|capitalize }}</h1>

            <div class="overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-gray-100">

                {% for conversation in conversationPagination %}
                    {# Find the other participant (not the current user) #}
                    {% set other = null %}
                    {% for participant in conversation.conversationParticipants %}
                        {% if participant.owner.id != app.user.id %}
                            {% set other = participant.owner %}
                        {% endif %}
                    {% endfor %}
                    {% set other = other ?? conversation.owner %}

                    {% set lastMessage = conversation.messages.last %}

                    <a href="{{ path('show_conversation', {id: conversation.id}) }}"
                       class="flex items-center gap-4 border-b border-gray-50 px-5 py-4 no-underline transition-colors last:border-0 hover:bg-gray-50">

                        {# Avatar #}
                        <div class="relative shrink-0">
                            <img src="{{ user_avatar(other) }}"
                                 class="h-11 w-11 rounded-full object-cover ring-2 ring-white shadow-sm"
                                 alt="{{ other.fullName }}">
                            <span class="absolute bottom-0 right-0 block h-3 w-3 rounded-full border-2 border-white bg-green-400"></span>
                        </div>

                        {# Name + preview #}
                        <div class="min-w-0 flex-1">
                            <div class="flex items-baseline justify-between gap-2">
                                <span class="truncate text-sm font-semibold text-gray-900">{{ other.fullName }}</span>
                                <span class="shrink-0 text-xs text-gray-400">
                                    {{ conversation.createdAt|format_datetime(timezone=regional.timezone, pattern=date_time_pattern) }}
                                </span>
                            </div>
                            <p class="mt-0.5 truncate text-sm text-gray-500">
                                {% if lastMessage %}
                                    {{ lastMessage.content|slice(0, 60) }}{% if lastMessage.content|length > 60 %}…{% endif %}
                                {% else %}
                                    <span class="italic">{{ 'no-messages-yet'|trans }}</span>
                                {% endif %}
                            </p>
                        </div>

                        {# Arrow #}
                        {{ ux_icon('mdi:chevron-right', {class: 'h-5 w-5 shrink-0 text-gray-300'}) }}

                    </a>

                {% else %}

                    <div class="flex flex-col items-center justify-center px-6 py-16 text-center">
                        {{ ux_icon('mdi:message-outline', {class: 'mx-auto mb-3 h-12 w-12 text-gray-200'}) }}
                        <p class="text-sm font-medium text-gray-500">{{ 'no-conversation-found'|trans }}</p>
                        <p class="mt-1 text-xs text-gray-400">{{ 'visit-a-profile-to-start'|trans }}</p>
                    </div>

                {% endfor %}

                {# Pagination #}
                {% if conversationPagination.getTotalItemCount() > conversationPagination.getItemNumberPerPage() %}
                    <div class="border-t border-gray-100 px-5 py-4">
                        {{ knp_pagination_render(conversationPagination) }}
                    </div>
                {% endif %}

            </div>
        </div>

    </div>
</div>
{% endblock %}
