{% extends 'base.html.twig' %}

{% block body %}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mt-3 flex flex-col justify-center gap-4 md:flex-row">
            <div class="w-full md:w-1/3">
                <div class="rounded-lg border border-gray-200 bg-white shadow-sm">
                    {{ include('partials/_account-navbar.html.twig') }}
                </div>
            </div>
            <div class="w-full md:w-1/2">
                <h2 class="mb-6 text-xl font-semibold text-gray-900">{{ 'contacts'|trans|capitalize }}</h2>

                <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
                    <div class="divide-y divide-gray-200">
                        {% for contact in contactsPagination %}
                            {% if contact.email.owner %}
                                <div class="px-4 py-3">
                                    <div class="flex items-center justify-between">
                                        <div class="flex items-center justify-start">
                                            <div>
                                                <a href="{{ path('show_profile', {id: contact.email.owner.id}) }}">
                                                    <img class="me-2 h-12 w-12 rounded-full object-cover"
                                                         src="{{ user_avatar(contact.email.owner) }}"
                                                         alt="{{ contact.email.owner.fullName }}"/>
                                                </a>
                                            </div>
                                            <div>
                                                <a href="{{ path('show_profile', {id: contact.email.owner.id}) }}" class="no-underline">
                                                    <div class="font-bold text-gray-900">{{ contact.email.owner.fullName }}</div>
                                                </a>
                                                <div class="text-sm text-gray-600">{{ contact.email.address }}</div>
                                            </div>
                                        </div>
                                        <div>
                                            <a class="text-red-600 hover:text-red-700" href="#">
                                                <i class="bi bi-x-circle text-2xl"></i>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            {% else %}
                                <div class="px-4 py-3">
                                    <div class="flex items-center justify-between">
                                        <div class="flex items-center justify-start">
                                            <div class="mdi mdi-at me-3 text-4xl text-gray-400"></div>
                                            <div class="text-gray-900">{{ contact.email.address }}</div>
                                        </div>
                                        <div>
                                            <a class="text-red-600 hover:text-red-700" href="#">
                                                <i class="bi bi-x-circle text-2xl"></i>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            {% endif %}
                        {% else %}
                            <div class="flex flex-col items-center justify-center px-6 py-16 text-center">
                                {{ ux_icon('mdi:account-multiple-outline', {class: 'mx-auto mb-3 h-12 w-12 text-gray-200'}) }}
                                <p class="text-sm font-medium text-gray-500">{{ 'no-contacts-found'|trans }}</p>
                            </div>
                        {% endfor %}
                        {% if  contactsPagination.getTotalItemCount() > contactsPagination.getItemNumberPerPage() %}
                            <div class="px-4 py-3">
                                {{ knp_pagination_render(contactsPagination, viewParams={align: 'center', size: 'medium'}) }}
                            </div>
                        {% endif %}
                    </div>
                </div>

            </div>
        </div>
    </div>
{% endblock %}