{% extends 'base.html.twig' %}

{% import "macro/event.macro.twig" as eventMacro %}


{% block body %}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mt-3 flex flex-col justify-center gap-4 md:flex-row">
            <div class="w-full md:w-1/3">
                <div class="rounded-lg border border-gray-200 bg-white shadow-sm">
                    {{ include('partials/_account-navbar.html.twig') }}
                </div>
            </div>
            <div class="w-full md:w-1/2">
                <h2 class="mb-4 text-xl font-semibold text-gray-900">{{ 'requests'|trans|capitalize }}</h2>
                <div class="flex flex-col gap-3">
                    {% for request in eventRequests %}
                        <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
                            <div class="flex">
                                <a href="{{ path('show_event', {id: request.event.id}) }}"
                                   class="flex w-3/4 items-center justify-start border-0 px-4 py-3 text-gray-900 no-underline hover:bg-gray-50">
                                    <div class="me-3">
                                        <img src="{{ vich_uploader_asset(request.event, 'imageFile') }}"
                                             class="h-12 w-12 rounded border border-gray-200 object-cover"/>
                                    </div>
                                    <div>
                                        <div class="font-bold">{{ request.event.title }}</div>
                                        <div class="flex items-center justify-between text-sm text-gray-600">
                                            <div class="mdi mdi-ray-start text-base"></div>
                                            <div>{{ request.event.startAt|format_datetime(timezone=regional.timezone,pattern=date_time_pattern) }}</div>
                                            <div class="mdi mdi-ray-vertex text-base"></div>
                                            <div>{{ request.event.endAt|format_datetime(timezone=regional.timezone,pattern=date_time_pattern) }}</div>
                                            <div class="mdi mdi-ray-end text-base"></div>
                                        </div>
                                    </div>
                                </a>
                                <a href="{{ path('cancel_event_rsvp_request', {id: request.id}) }}"
                                   class="flex w-1/4 flex-col items-center justify-center border-0 border-l border-gray-200 px-4 py-3 text-center text-gray-900 no-underline hover:bg-gray-50">
                                    <div class="bi bi-x-circle text-xl text-red-600"></div>
                                    <div class="text-sm">{{ 'cancel-request'|trans }}</div>
                                </a>
                            </div>
                        </div>
                    {% else %}
                        <div class="overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-gray-100">
                            <div class="flex flex-col items-center justify-center px-6 py-16 text-center">
                                {{ ux_icon('mdi:clock-outline', {class: 'mx-auto mb-3 h-12 w-12 text-gray-200'}) }}
                                <p class="text-sm font-medium text-gray-500">{{ 'no-requests-found'|trans }}</p>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}