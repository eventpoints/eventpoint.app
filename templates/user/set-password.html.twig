{% extends 'base.html.twig' %}

{% block title %}{{ 'password.set-title'|trans }}{% endblock %}

{% block body %}
    <div class="flex min-h-[calc(100vh-200px)] items-center justify-center px-4 py-12">
        <div class="w-full max-w-md">
            <div class="mb-8 text-center">
                <h1 class="text-2xl font-semibold tracking-tight text-gray-900">{{ 'password.set-title'|trans }}</h1>
                <p class="mt-2 text-sm text-gray-500">{{ 'password.set-subtitle'|trans }}</p>
            </div>

            <div class="overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-gray-100">
                <div class="p-6">
                    {{ form_start(passwordForm, {'attr': {'class': 'space-y-4'}}) }}
                        <div>
                            {{ form_label(passwordForm.plainPassword.first, null, {label_attr: {class: 'mb-1.5 block text-sm font-medium text-gray-700'}}) }}
                            {{ form_widget(passwordForm.plainPassword.first) }}
                            {{ form_errors(passwordForm.plainPassword.first) }}
                        </div>
                        <div>
                            {{ form_label(passwordForm.plainPassword.second, null, {label_attr: {class: 'mb-1.5 block text-sm font-medium text-gray-700'}}) }}
                            {{ form_widget(passwordForm.plainPassword.second) }}
                            {{ form_errors(passwordForm.plainPassword.second) }}
                        </div>

                        <button type="submit"
                                class="mt-2 w-full rounded-lg bg-gray-900 px-5 py-3 text-sm font-medium text-white transition-colors hover:bg-gray-800">
                            {{ 'password.set-button'|trans }}
                        </button>
                    {{ form_end(passwordForm) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
