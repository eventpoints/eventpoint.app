{% extends 'base.html.twig' %}

{% block body %}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mt-3 flex flex-col justify-center gap-4 md:flex-row">
            <div class="w-full md:w-1/3">
                <div class="rounded-lg border border-gray-200 bg-white shadow-sm">
                    {{ include('partials/_account-navbar.html.twig') }}
                </div>
            </div>
            <div class="w-full md:w-1/2">
                <div class="text-right text-2xl font-bold">{{ 'groups'|trans|upper }}</div>
                <hr class="mt-0 border-gray-200"/>
                <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
                    <div class="divide-y divide-gray-200">
                        {% for group in groups %}
                            <a href="{{ path('event_group_show', {id: group.id }) }}"
                               class="flex items-start justify-between px-4 py-3 text-gray-900 no-underline hover:bg-gray-50">
                                <div>
                                    <div class="font-bold">{{ group.name }}</div>
                                </div>
                                <div>
                                    <div class="inline-flex items-center justify-between gap-2 rounded-full bg-blue-100 px-2.5 py-0.5 text-base font-medium text-blue-800">
                                        <span class="bi bi-people"></span>
                                        <span>{{ group.eventGroupMembers.count }}</span>
                                    </div>
                                </div>
                            </a>
                        {% else %}
                            <div class="px-4 py-3 text-center font-bold text-gray-500">{{ 'no-groups-found'|trans }}</div>
                        {% endfor %}
                    </div>
                </div>

            </div>
        </div>
    </div>
{% endblock %}