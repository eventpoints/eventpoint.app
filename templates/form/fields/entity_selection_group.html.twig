{# templates/form/fields/entity_selection_group.html.twig #}

{% block entity_selection_group_widget %}
    {% if not expanded %}
        {{ block('choice_widget_collapsed') }}
    {% else %}
        {% set searchable = searchable|default(false) %}
        {% set empty_message = empty_message|default('no-select-options'|trans) %}

        {% set existing_controller = attribute(attr, 'data-controller')|default('') %}
        {% set attr = attr|merge({
            'data-controller': (existing_controller ~ ' entity-selection-group')|trim,
            'data-entity-selection-group-min-chars-value': 1,
            class: (attr.class|default('') ~ ' overflow-hidden rounded-lg border border-gray-200 bg-white')|trim
        }) %}

        <div {{ block('widget_container_attributes') }}>
            {% if searchable %}
                <div class="border-b border-gray-200 p-4">
                    <label for="{{ id }}_search" class="sr-only">{{ 'search'|trans }}</label>

                    <div class="relative">
                        <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                            <svg class="h-4 w-4 text-gray-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 20">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="m19 19-4-4m0-7a7 7 0 1 1-14 0 7 7 0 0 1 14 0Z"/>
                            </svg>
                        </div>

                        <input
                                type="text"
                                id="{{ id }}_search"
                                class="block w-full rounded-lg border border-gray-300 bg-gray-50 p-2.5 pl-10 text-sm text-gray-900 focus:border-[#660033] focus:ring-2 focus:ring-[#660033]/20"
                                placeholder="{{ 'search'|trans }}"
                                data-entity-selection-group-target="search"
                                data-action="input->entity-selection-group#filter"
                        >
                    </div>
                </div>
            {% endif %}

            {% if form|length == 0 %}
                <div class="p-4 text-sm text-gray-500">{{ empty_message }}</div>
            {% else %}
                <ul class="divide-y divide-gray-200">
                    {% for child in form %}
                        {% set is_radio = 'radio' in child.vars.block_prefixes %}
                        {% set input_classes = is_radio
                            ? 'h-10 w-10 shrink-0 border-gray-300 text-[#660033] focus:outline-none focus:ring-2 focus:ring-[#660033]/25 focus:ring-offset-0'
                            : 'h-10 w-10 shrink-0 rounded-md border-gray-300 text-[#660033] focus:outline-none focus:ring-2 focus:ring-[#660033]/25 focus:ring-offset-0'
                        %}

                        <li class="hover:bg-gray-50" data-entity-selection-group-target="item">
                            {# whole row clickable; text left, control right #}
                            <label class="flex w-full cursor-pointer items-center justify-between gap-6 px-4 py-4">
                <span class="min-w-0 flex-1 text-sm font-medium text-gray-900">
                    {{ child.vars.label }}
                </span>

                                {# Render ONLY the input (no label), bypassing your checkbox theme #}
                                {% set merged_attr = child.vars.attr|merge({
                                    class: (child.vars.attr.class|default('') ~ ' ' ~ input_classes)|trim
                                }) %}

                                {% with { form: child, attr: merged_attr } %}
                                    <input
                                            type="{{ is_radio ? 'radio' : 'checkbox' }}"
                                            {{ block('widget_attributes') }}
                                            value="{{ child.vars.value }}"
                                            {% if child.vars.checked %}checked="checked"{% endif %}
                                    >
                                {% endwith %}
                            </label>
                        </li>
                    {% endfor %}
                </ul>

                <div class="hidden p-4 text-sm text-gray-500" data-entity-selection-group-target="empty">
                    {{ empty_message }}
                </div>
            {% endif %}
        </div>
    {% endif %}
{% endblock %}