{#
    SelectionType — Flowbite card-style radio / checkbox widget

    Usage:
        ->add('field', SelectionType::class, [
            'choices'  => ['Label A' => 'a', 'Label B' => 'b'],
            'multiple' => false,   // false = radios (default), true = checkboxes
            'cols'     => 2,       // 1 | 2 | 3 | 4 grid columns (default 2)

            // Optional per-choice extras via choice_attr:
            //   data-icon        — ux_icon name, e.g. 'mdi:lock'
            //   data-description — subtitle shown below the label
            'choice_attr' => [
                'Label A' => ['data-icon' => 'mdi:lock', 'data-description' => 'Subtitle text'],
            ],
        ])
#}

{% block selection_type_widget %}
    {%- if expanded -%}
        {{- block('selection_type_widget_expanded') -}}
    {%- else -%}
        {{- block('choice_widget_collapsed') -}}
    {%- endif -%}
{% endblock %}

{% block selection_type_widget_expanded %}
    {%- set col_class = {1: 'grid-cols-1', 2: 'grid-cols-2', 3: 'grid-cols-3', 4: 'grid-cols-4'}[cols|default(2)]|default('grid-cols-2') -%}

    <ul class="select-none grid w-full gap-3 {{ col_class }}" {{ block('widget_container_attributes') }}>
        {%- for child in form -%}
            {%- if child.vars.value != '' -%}
                {%- set icon        = child.vars.attr['data-icon']|default(null) -%}
                {%- set description = child.vars.attr['data-description']|default(null) -%}
                {%- set is_disabled = disabled or child.vars.disabled -%}
                {%- set choice_label = choice_translation_domain is same as(false)
                    ? child.vars.label
                    : child.vars.label|trans({}, choice_translation_domain ?? child.vars.translation_domain) -%}

                <li>
                    <input
                        type="{{ multiple ? 'checkbox' : 'radio' }}"
                        id="{{ child.vars.id }}"
                        name="{{ child.vars.full_name }}"
                        value="{{ child.vars.value }}"
                        class="peer hidden"
                        {% if child.vars.checked %}checked{% endif %}
                        {% if is_disabled %}disabled{% endif %}
                        {% if required and not multiple %}required{% endif %}
                    >
                    <label for="{{ child.vars.id }}"
                           class="inline-flex w-full cursor-pointer items-center justify-between rounded-lg border border-gray-200 bg-white p-5 text-gray-500 transition-colors hover:bg-gray-50 hover:text-gray-600 peer-checked:border-primary-500 peer-checked:bg-primary-50 peer-checked:text-primary-700 peer-checked:hover:bg-primary-100 peer-disabled:cursor-not-allowed peer-disabled:opacity-50">
                        <div class="block">
                            {%- if icon -%}
                                {{ ux_icon(icon, {class: 'mb-2 h-7 w-7'}) }}
                            {%- endif -%}
                            <div class="font-medium{% if description %} mb-1{% endif %}">{{ choice_label }}</div>
                            {%- if description -%}
                                <div class="text-sm">{{ description }}</div>
                            {%- endif -%}
                        </div>
                    </label>
                </li>
            {%- endif -%}
        {%- endfor -%}
    </ul>
{% endblock %}

{% block selection_type_label %}
    {%- if label is not same as(false) and label is not empty -%}
        <label{% if not compound %} for="{{ id }}"{% endif %} class="mb-2 block text-sm font-medium text-gray-900">
            {{- label|trans({}, translation_domain) -}}
            {%- if required -%}<span class="ml-0.5 text-red-500">*</span>{%- endif -%}
        </label>
    {%- endif -%}
{% endblock %}

{% block selection_type_row %}
    <div class="{{ row_attr.class|default('mb-4') }}">
        {{- block('selection_type_label') -}}
        {{- block('form_widget') -}}
        {%- if errors|length > 0 -%}
            <ul class="mt-1.5 space-y-0.5">
                {%- for error in errors -%}
                    <li class="text-sm text-red-600">{{ error.message }}</li>
                {%- endfor -%}
            </ul>
        {%- endif -%}
        {%- if help is not empty -%}
            <p class="mt-1.5 text-sm text-gray-500">{{ help|trans({}, help_translation_domain) }}</p>
        {%- endif -%}
    </div>
{% endblock %}
