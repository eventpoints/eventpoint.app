<turbo-frame id="regional_settings_frame" target="_top">
    {{ form_start(regionForm, { action: path('_app_regional_settings') }) }}

    <div class="divide-y divide-gray-100">

        <div class="px-6 py-4">
            {{ form_label(regionForm.locale, null, {label_attr: {class: 'mb-1.5 block text-sm font-medium text-gray-700'}}) }}
            {{ form_widget(regionForm.locale, {attr: {class: 'block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-primary-500 focus:ring-primary-500'}}) }}
        </div>

        <div class="px-6 py-4">
            {{ form_label(regionForm.region, null, {label_attr: {class: 'mb-1.5 block text-sm font-medium text-gray-700'}}) }}
            {{ form_widget(regionForm.region, {attr: {class: 'block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-primary-500 focus:ring-primary-500'}}) }}
        </div>

<div class="px-6 py-4">
            {{ form_label(regionForm.currency, null, {label_attr: {class: 'mb-1.5 block text-sm font-medium text-gray-700'}}) }}
            {{ form_widget(regionForm.currency, {attr: {class: 'block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2.5 text-sm text-gray-900 focus:border-primary-500 focus:ring-primary-500'}}) }}
        </div>

    </div>

    <div class="border-t border-gray-100 px-6 py-4">
        <button type="submit"
                class="w-full rounded-lg bg-primary-600 px-4 py-2.5 text-center text-sm font-semibold text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-4 focus:ring-primary-300">
            {{ 'save'|trans }}
        </button>
    </div>

    {{ form_end(regionForm) }}
</turbo-frame>
