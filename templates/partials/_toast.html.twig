<div id="{{ toast_id }}" class="flex w-full gap-3 items-center rounded-lg bg-gray-900 p-4 shadow-lg" role="alert">
    <span class="bi bi-send-fill text-lg text-white"></span>
    <div class="ms-3 text-sm text-white">{{ message|trans }}</div>
    <button type="button"
            class="ms-auto inline-flex h-8 w-8 items-center justify-center rounded-lg text-gray-400 hover:bg-gray-700 hover:text-white focus:outline-none"
            data-dismiss-target="#{{ toast_id }}"
            aria-label="{{ 'close'|trans }}">
        <span class="sr-only">{{ 'close'|trans }}</span>
        {{ ux_icon('mdi:close', {class: 'h-5 w-5'}) }}
    </button>
</div>
