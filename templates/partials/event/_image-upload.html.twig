{% if event.isAfterStart %}
    <div class="mb-3 rounded-lg border border-gray-200 bg-white shadow-sm">
        <div class="p-4">
            {{ form_start(imageForm) }}
            {{ form_widget(imageForm.images) }}
            <div class="text-right mt-3">
                <button type="submit"
                        class="rounded-lg bg-primary-600 hover:bg-primary-700 px-5 py-2.5 text-sm font-medium text-white hover:bg-blue-800">{{ 'upload'|trans }}</button>
            </div>
            {{ form_end(imageForm) }}
        </div>
    </div>
    <div>
        <div class="relative">
            {% for imageCollection in event.imageCollections %}
                <div class="rounded-lg border-0 bg-gray-100 p-4 text-gray-800">
                    <div class='relative' {{ stimulus_controller('lightbox image-grid') }}
                         data-lightbox-options-value='{"thumbnails": true}'
                    >
                        {% for image in imageCollection.images %}
                            <img class="rounded object-cover" src="{{ vich_uploader_asset(image, 'imageFile') }}"
                                 alt="event image"/>
                        {% endfor %}
                    </div>
                    <div>
                        <a href="{{ path('show_profile', {id: imageCollection.owner.id}) }}"
                           class="flex items-center gap-3 border-b border-gray-50 px-4 py-3 no-underline transition-colors last:border-0 hover:bg-gray-50">
                            <img src="{{ user_avatar(imageCollection.owner) }}"
                                 class="h-9 w-9 rounded-full object-cover ring-2 ring-white shadow-sm"
                                 alt="{{ imageCollection.owner.fullName }}">
                            <span class="text-sm font-medium text-gray-900">{{ imageCollection.owner.fullName }}</span>
                        </a>
                    </div>
                </div>

                <div class="mb-3 text-right text-sm text-gray-500">{{ imageCollection.createdAt|time_ago }}</div>

                {% if not loop.last %}
                    <div class="text-center">
                        <div class="vh-5 mx-auto border-l border-gray-300"></div>
                    </div>
                {% endif %}

            {% endfor %}
        </div>
    </div>
{% endif %}
