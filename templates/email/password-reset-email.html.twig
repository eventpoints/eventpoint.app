{% extends 'email/base-email.html.twig' %}

{% block content %}
    <h1 style="margin:0 0 8px;font-size:22px;font-weight:700;color:#111827;">{{ 'email.password-reset.header'|trans }}</h1>
    <p style="margin:0 0 24px;font-size:15px;line-height:1.6;color:#4b5563;">
        {{ 'email.password-reset.body'|trans }}
    </p>

    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 24px;">
        <tr>
            <td align="center">
                <a href="{{ url('user_set_password', {token: token.value}) }}"
                   style="display:inline-block;background-color:#660033;color:#ffffff;font-size:15px;font-weight:600;text-decoration:none;padding:12px 28px;border-radius:8px;">
                    {{ 'email.password-reset.cta'|trans }}
                </a>
            </td>
        </tr>
    </table>

    <p style="margin:0 0 24px;font-size:13px;color:#9ca3af;text-align:center;">
        {{ 'link-expires-in'|trans }} {{ token.hoursUntilExpiry }} {{ 'hours'|trans }}
    </p>

    <hr style="border:0;border-top:1px solid #f3f4f6;margin:0 0 24px;"/>
    <p style="margin:0;font-size:14px;color:#6b7280;">{{ 'email-sign-off'|trans }}</p>
{% endblock %}
