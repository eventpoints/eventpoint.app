<div {{ attributes }}>
    {% if not this.event.hasRated(app.user) %}
        <div class="rounded-xl border border-gray-200 bg-white p-4">
            <p class="mb-4 font-semibold text-gray-900">{{ 'how-was-it'|trans }}</p>

            {% if this.venueRating is null %}
                {% set step_action = 'setVenueRating' %}
                {% set step_title = 'venue-rating'|trans %}
                {% set step_explainer = 'venue-rating-explainer'|trans %}
            {% elseif this.contentRating is null %}
                {% set step_action = 'setContentRating' %}
                {% set step_title = 'content-rating'|trans %}
                {% set step_explainer = 'content-rating-explainer'|trans %}
            {% elseif this.hostRating is null %}
                {% set step_action = 'setHostRating' %}
                {% set step_title = 'host-rating'|trans %}
                {% set step_explainer = 'host-rating-explainer'|trans %}
            {% elseif this.guestRating is null %}
                {% set step_action = 'setGuestRating' %}
                {% set step_title = 'guest-rating'|trans %}
                {% set step_explainer = 'guest-rating-explainer'|trans %}
            {% else %}
                {% set step_action = 'setExpectationRating' %}
                {% set step_title = 'expectation-rating'|trans %}
                {% set step_explainer = 'expectation-rating-explainer'|trans %}
            {% endif %}

            <div class="flex items-center justify-between gap-4">
                <div>
                    <p class="font-medium text-gray-900">{{ step_title }}</p>
                    <p class="text-sm text-gray-500">{{ step_explainer }}</p>
                </div>
                <div class="flex shrink-0 gap-1">
                    {% for i in 1..5 %}
                        <button
                            data-action="live#action:prevent"
                            data-live-action-param="{{ step_action }}"
                            data-live-rating-param="{{ i }}"
                            class="text-gray-400 hover:text-yellow-400 focus:outline-none">
                            {{ ux_icon('mdi:star', {class: 'h-8 w-8'}) }}
                        </button>
                    {% endfor %}
                </div>
            </div>
        </div>
    {% else %}
        <div class="flex items-center justify-center gap-2 rounded-xl border border-primary-200 bg-primary-50 p-4 text-center">
            {{ ux_icon('mdi:check-circle', {class: 'h-5 w-5 text-green-500'}) }}
            <span class="text-sm text-gray-600">{{ 'thanks-for-the-feedback'|trans }}</span>
        </div>
    {% endif %}
</div>
