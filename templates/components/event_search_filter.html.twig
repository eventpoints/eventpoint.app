<div {{ attributes }} >
    <div {{ stimulus_controller('dynamic-map', {
        token: mapbox_token,
        events: jsonEvents,
        interactive: true,
    }) }} >

        <div class="h-56 w-full shadow-sm fixed top-0" {{ stimulus_target('dynamic-map', 'map') }}></div>

        <div class="flex flex-col xl:flex-row h-auto w-full">
            <div class="w-full xl:w-72 flex-shrink-0 border-r border-gray-100 order-1 xl:order-1">
                <div class="flex flex-col h-full">
                    <div class="p-5 pb-3">
                        <h2 class="text-sm font-medium uppercase tracking-wider text-gray-400">{{ 'filters'|trans }}</h2>
                    </div>
                    <div class="flex-1 px-4 pb-4">
                        {{ form_start(form, {
                            attr: {
                                'novalidate': true,
                                'data-action': 'live#action:prevent',
                                'data-live-action-param': 'search',
                            }
                        }) }}
                        <div class="space-y-4">
                            <div>
                                {{ form_row(form.keyword) }}
                            </div>
                            {% if form.city is defined %}
                                <div>
                                    {{ form_row(form.city, {
                                        attr: {
                                            "data-action" : "change->map-raduis#drawCircle"
                                        }
                                    }) }}
                                </div>
                            {% endif %}
                            <div>{{ form_row(form.category) }}</div>
                            <div>{{ form_row(form.period) }}</div>
                        </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
            <div class="flex-1 order-2 xl:order-2">
                <div class="mx-auto p-5">
                    <div class="space-y-4">
                        {% for group in groups %}
                            <div class="rounded-xl bg-white shadow-sm ring-1 ring-gray-200">
                                <div class="p-4 text-center">
                                    <div>
                                        <img src="{{ group.base64Image }}"
                                             class="mx-auto mb-3 rounded-full object-cover"
                                             height="50"
                                             width="50"/>
                                    </div>
                                    <div class="font-medium text-gray-900">{{ group.name }}</div>
                                </div>
                            </div>
                        {% endfor %}

                        {% for event in events %}
                            <div>
                                {% if event.url %}
                                    {{ include('partials/event/_external-event-card.html.twig') }}
                                {% else %}
                                    <twig:EventCard :event="event" :hasMap="true" :hasLink="true"/>
                                {% endif %}
                            </div>
                        {% else %}
                            <div class="py-12 text-center">
                                <p class="text-sm font-medium uppercase tracking-wider text-gray-400">{{ 'no-events-found'|trans }}</p>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
            <div class="w-full xl:w-64 flex-shrink-0 overflow-y-auto border-l border-gray-100 order-3 xl:order-3 hidden xl:block">
                <div class="p-5">
                </div>
            </div>
        </div>
    </div>
</div>
