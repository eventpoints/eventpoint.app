<div {{ attributes }} >

    {{ form_start(form) }}
    <div class="card mb-5">
        <div class="card-header fs-5 fw-bold">{{ 'create-event-group'|trans|capitalize }}</div>
        <div class="list-group list-group-flush">
            <div class="list-group-item">{{ form_row(form.name) }}</div>
            <div class="list-group-item">{{ form_row(form.description) }}</div>
            <div class="list-group-item">{{ form_row(form.language) }}</div>
            <div class="list-group-item">{{ form_row(form.categories) }}</div>
        </div>
        <div class="card-footer text-end">
            <button type="submit" class="btn btn-primary">{{ 'create'|trans }}</button>
        </div>
    </div>
    {{ form_end(form) }}
</div>