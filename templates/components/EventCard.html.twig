{% props event, hasMap = false, hasLink = false, hasHeader = false %}
<div class="overflow-hidden border border-gray-100 rounded-xl bg-white shadow-sm ring-1 ring-gray-200 transition-all duration-300 hover:shadow-md"
     data-dynamic-map-event-id="{{ event.id }}"
     data-event-card-highlight>
    {% if event.eventCancellation %}
        <div class="flex items-center justify-center bg-gray-50 py-3 text-center">
            <span class="text-xs font-medium uppercase tracking-widest text-gray-500">{{ 'event-canceled'|trans }}</span>
        </div>
    {% else %}
        <div class="flex">
            <div class="flex min-w-[80px] flex-col items-center justify-center border-r border-gray-100 py-5 text-center">
                <span class="text-xs font-medium uppercase tracking-wider text-gray-400">{{ event.startAt|format_date(timezone=regional.timezone,pattern='MMM')|upper }}</span>
                <span class="text-3xl font-light text-gray-900">{{ event.startAt|format_date(timezone=regional.timezone,pattern='d') }}</span>
                <span class="mt-1 text-xs font-medium text-gray-400">{{ event.startAt|format_date(timezone=regional.timezone,pattern='EEE') }}</span>
            </div>
            <div class="flex-1 p-4">
                <div class="flex justify-between items-start">
                    <a href="{{ path('show_event', {id: event.id}) }}" class="block">
                        <h3 class="mb-1 text-base font-medium text-gray-900 transition-colors hover:text-gray-700 line-clamp-1">
                            {{ event.title }}
                        </h3>
                    </a>
                    <div class="flex -space-x-2">
                        {% if hasMap %}
                            <div>
                                <a
                                        {{ stimulus_action('dynamic-map', 'flyToAssetOnMap', 'click', {
                                            id: event.id,
                                            longitude: event.longitude,
                                            latitude: event.latitude
                                        }) }}
                                        class="inline-flex h-10 w-10 cursor-pointer items-center justify-center rounded-full text-gray-500 transition-colors hover:bg-gray-100 hover:text-gray-900"
                                        title="locate"
                                        aria-label="locate event on map"
                                >
                                    {{ ux_icon('mdi:location',  { class: 'text-xl' }) }}
                                </a>
                            </div>
                        {% endif %}
                        <div data-controller="clipboard" data-clipboard-success-content-value="copied">
                            <input
                                    type="text"
                                    class="sr-only"
                                    readonly
                                    value="{{ absolute_url(path('show_event', { id: event.id })) }}"
                                    data-clipboard-target="source"
                            >

                            <a
                                    href="#"
                                    data-action="click->clipboard#copy"
                                    data-clipboard-target="button"
                                    class="inline-flex h-10 w-10 cursor-pointer items-center justify-center rounded-full text-gray-500 transition-colors hover:bg-gray-100 hover:text-gray-900"
                                    title="Share"
                                    aria-label="Copy event link"
                            >
                                {{ ux_icon('mdi:content-copy',  { class: 'text-xl' }) }}
                            </a>
                        </div>
                    </div>
                </div>
                <div class="flex items-center gap-1 text-gray-500">
                    <span class="bi bi-clock text-gray-400"></span>
                    <span class="text-3xl font-light text-gray-900">{{ event.startAt|format_time(timezone=regional.timezone,pattern=time_pattern) }}</span>
                </div>
            </div>
        </div>

        {% if event.base64Image %}
            <div class="h-40 w-full">
                <img src="{{ event.base64Image }}" class="h-full w-full object-cover" alt="{{ event.title }}">
            </div>
        {% endif %}

        <div class="border-t border-gray-100 px-4 py-3">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="flex -space-x-2">
                        {% set maxAvatars = 3 %}
                        {% for i in 0..(min(event.allParticipantsCount - 1, maxAvatars - 1)) %}
                            <img src="{{ event.owner.avatar }}"
                                 class="h-8 w-8 rounded-full border-2 border-white object-cover shadow-sm"
                                 alt="">
                        {% endfor %}
                        {% if event.allParticipantsCount > maxAvatars %}
                            <div class="flex h-8 w-8 items-center justify-center rounded-full border-2 border-white bg-gray-100 text-xs font-medium text-gray-600 shadow-sm">
                                +{{ event.allParticipantsCount - maxAvatars }}
                            </div>
                        {% endif %}
                    </div>
                    <span class="text-xs text-gray-500">{{ event.allParticipantsCount }} {{ 'going'|trans }}</span>
                </div>
                <a href="{{ path('show_event', {id: event.id}) }}"
                   class="text-xs font-medium text-gray-900 hover:text-gray-600">
                    {{ 'view-event'|trans }} →
                </a>
            </div>
        </div>
    {% endif %}
</div>
