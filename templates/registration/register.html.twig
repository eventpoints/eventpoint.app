{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}
    <div class="min-h-[calc(100vh-200px)] px-4 py-12">
        <div class="mx-auto max-w-5xl">
            <div class="flex flex-col items-center gap-12 lg:flex-row lg:items-start lg:gap-16">
                {# Left side - branding #}
                <div class="w-full max-w-md text-center lg:w-1/2 lg:text-left">
                    <div class="lg:sticky lg:top-24">
                        <h1 class="text-4xl font-semibold tracking-tight text-gray-900 lg:text-5xl">{{ app_name|title }}</h1>
                        <p class="mt-4 text-lg text-gray-500">{{ 'app-explainer'|trans }}</p>
                        <div class="mt-8 hidden lg:block">
                            <div class="flex items-center gap-4 rounded-xl bg-gray-50 p-4">
                                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-gray-900 text-white">
                                    {{ ux_icon('mdi:calendar-check', {class: 'h-5 w-5'}) }}
                                </div>
                                <div class="text-sm text-gray-600">
                                    <span class="font-medium text-gray-900">Discover events</span> in your area and connect with your community
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                {# Right side - form #}
                <div class="w-full max-w-md lg:w-1/2">
                    <div class="overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-gray-100">
                        <div class="p-6">

                            {{ form_errors(registrationForm.email) }}

                            {{ form_start(registrationForm) }}
                            <div class="space-y-4">
                                <div class="grid grid-cols-2 gap-4">
                                    <div>
                                        <label class="mb-1.5 block text-sm font-medium text-gray-700">{{ 'first-name'|trans|default('First name') }}</label>
                                        {{ form_widget(registrationForm.firstName, {attr: {class: 'block w-full rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-900 transition-colors focus:border-gray-400 focus:bg-white focus:outline-none focus:ring-0'}}) }}
                                    </div>
                                    <div>
                                        <label class="mb-1.5 block text-sm font-medium text-gray-700">{{ 'last-name'|trans|default('Last name') }}</label>
                                        {{ form_widget(registrationForm.lastName, {attr: {class: 'block w-full rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-900 transition-colors focus:border-gray-400 focus:bg-white focus:outline-none focus:ring-0'}}) }}
                                    </div>
                                </div>
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-gray-700">{{ 'email'|trans }}</label>
                                    {{ form_widget(registrationForm.email, {attr: {class: 'block w-full rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-900 transition-colors focus:border-gray-400 focus:bg-white focus:outline-none focus:ring-0'}}) }}
                                </div>
                                <div>
                                    <label class="mb-1.5 block text-sm font-medium text-gray-700">{{ 'password'|trans }}</label>
                                    {{ form_widget(registrationForm.plainPassword) }}
                                </div>
                            </div>

                            <div class="cf-turnstile" data-sitekey="{{ turnstile_public_key }}" data-size="invisible"></div>

                            <button type="submit"
                                    class="mt-6 w-full rounded-lg bg-gray-900 px-5 py-3 text-sm font-medium text-white transition-colors hover:bg-gray-800">
                                {{ 'create-account'|trans|default('Create account') }}
                            </button>

                            {{ form_end(registrationForm) }}
                        </div>
                    </div>

                    <p class="mt-6 text-center text-sm text-gray-500">
                        {{ 'already-have-account'|trans|default('Already have an account?') }}
                        <a href="{{ path('app_login') }}" class="font-medium text-gray-900 no-underline hover:underline">{{ 'sign-in'|trans }}</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
{% endblock %}
