{% extends 'base.html.twig' %}

{% block title %}Login{% endblock %}

{% block body %}
    <div class="flex min-h-[calc(100vh-200px)] items-center justify-center px-4 py-12">
        <div class="w-full max-w-md">
            <div class="mb-8 text-center">
                <h1 class="text-2xl font-semibold tracking-tight text-gray-900">{{ 'welcome-back'|trans|default('Welcome back') }}</h1>
                <p class="mt-2 text-sm text-gray-500">{{ 'sign-in-to-continue'|trans|default('Sign in to continue to Event Point') }}</p>
            </div>

            <div class="overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-gray-100">
                <div class="p-6">
                    <form method="post">
                        {% if error %}
                            <div class="mb-4 rounded-lg border border-red-100 bg-red-50 p-4 text-sm text-red-700">
                                {{ error.messageKey|trans(error.messageData, 'security') }}
                            </div>
                        {% endif %}

                        <div class="space-y-4">
                            <div>
                                <label for="inputEmail" class="mb-1.5 block text-sm font-medium text-gray-700">{{ 'email-or-phone-number'|trans }}</label>
                                <input type="text" value="{{ last_username }}" name="email" id="inputEmail"
                                       class="block w-full rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-900 transition-colors focus:border-gray-400 focus:bg-white focus:outline-none focus:ring-0"
                                       autocomplete="email" placeholder="{{ 'email-placeholder'|trans }}" required autofocus>
                            </div>
                            <div>
                                <label for="inputPassword" class="mb-1.5 block text-sm font-medium text-gray-700">{{ 'password'|trans }}</label>
                                <div class="flex rounded-lg border border-gray-200 bg-gray-50 transition-colors focus-within:border-gray-400 focus-within:bg-white" {{ stimulus_controller('password-visibility') }}>
                                    <input type="password" name="password" id="inputPassword"
                                           class="block w-full rounded-l-lg bg-transparent px-4 py-3 text-sm text-gray-900 focus:outline-none focus:ring-0"
                                           autocomplete="current-password" required placeholder="{{ 'password-placeholder'|trans }}"
                                           data-password-visibility-target="input">
                                    <button type="button"
                                            class="flex items-center px-3 text-gray-400 hover:text-gray-600"
                                            data-action="password-visibility#toggle">
                                        <span data-password-visibility-target="icon">{{ ux_icon('mdi:eye-outline', {class: 'h-5 w-5'}) }}</span>
                                        <span data-password-visibility-target="icon" class="hidden">{{ ux_icon('mdi:eye-off-outline', {class: 'h-5 w-5'}) }}</span>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                        <button class="mt-6 w-full rounded-lg bg-gray-900 px-5 py-3 text-sm font-medium text-white transition-colors hover:bg-gray-800" type="submit">
                            {{ 'sign-in'|trans }}
                        </button>

                        <p class="mt-4 text-center text-sm text-gray-500">
                            <a href="{{ path('request_password_reset') }}" class="font-medium text-gray-700 no-underline hover:underline">{{ 'password.forgot'|trans }}</a>
                        </p>
                    </form>
                </div>
            </div>

            <p class="mt-6 text-center text-sm text-gray-500">
                {{ 'dont-have-account'|trans|default("Don't have an account?") }}
                <a href="{{ path('app_register') }}" class="font-medium text-gray-900 no-underline hover:underline">{{ 'register'|trans }}</a>
            </p>
        </div>
    </div>
{% endblock %}
