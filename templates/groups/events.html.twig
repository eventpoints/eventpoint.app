{% extends 'base.html.twig' %}

{% block body %}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mt-3 flex flex-col justify-center gap-4 md:flex-row">
            <div class="w-full md:w-1/3">
                {{ include('partials/_event-group-navbar.html.twig') }}
            </div>
            <div class="w-full md:w-1/2">
                <div class="grid grid-cols-1 gap-2 md:grid-cols-2">
                    {% for event in eventGroup.events %}
                        <div>
                            <twig:EventCard :event="event" />
                        </div>
                    {% else %}
                        <div class="mt-5 text-center font-bold text-gray-500">{{ 'no-events-found'|trans|upper }}</div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
