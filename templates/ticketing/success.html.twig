{% extends 'base.html.twig' %}

{% block title %}{{ 'ticketing.success.page_title'|trans }} - Event Point{% endblock %}

{% block body %}
<div class="mx-auto max-w-lg px-4 py-12">
    <div class="rounded-lg border border-gray-200 bg-white p-8 shadow-sm text-center">
        <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-green-100">
            <svg class="h-8 w-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
        </div>

        <h1 class="mb-2 text-2xl font-bold text-gray-900">{{ 'ticketing.success.title'|trans }}</h1>
        <p class="mb-6 text-gray-600">{{ 'ticketing.success.description'|trans }}</p>

        {% if order %}
            <div class="mb-6 rounded-lg bg-gray-50 p-4 text-left">
                <p class="text-sm text-gray-500">{{ 'ticketing.success.order_reference'|trans }}</p>
                <p class="font-mono font-medium text-gray-900">{{ order.id }}</p>
                <p class="mt-2 text-sm text-gray-500">{{ 'ticketing.success.event'|trans }}</p>
                <p class="font-medium text-gray-900">{{ order.event.title }}</p>
                <p class="mt-2 text-sm text-gray-500">{{ 'ticketing.success.total'|trans }}</p>
                <p class="font-medium text-gray-900">{{ (order.totalAmountCents / 100)|number_format(2) }} {{ order.currency }}</p>
            </div>

            <div class="flex flex-col gap-3 sm:flex-row sm:justify-center">
                <a href="{{ path('order_detail', {'id': order.id}) }}"
                   class="rounded-lg border border-gray-300 px-6 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-50">
                    {{ 'ticketing.success.view_order'|trans }}
                </a>
                <a href="{{ path('show_event', {'id': order.event.id}) }}"
                   class="rounded-lg bg-blue-600 px-6 py-2.5 text-sm font-medium text-white hover:bg-blue-700">
                    {{ 'ticketing.success.back_to_event'|trans }}
                </a>
            </div>
        {% else %}
            <a href="{{ path('events') }}"
               class="inline-block rounded-lg bg-blue-600 px-6 py-2.5 text-sm font-medium text-white hover:bg-blue-700">
                {{ 'ticketing.success.back_to_home'|trans }}
            </a>
        {% endif %}
    </div>
</div>
{% endblock %}
