{% set td = (translation_domain is defined ? translation_domain : null) %}
{% if td == '' %}{% set td = null %}{% endif %}

{% if results is empty %}
    <div class="px-4 py-3 text-sm text-gray-500">No results</div>
{% else %}
    <div class="grid grid-cols-3 gap-2 p-2" role="listbox" aria-label="Autocomplete results">
        {% for item in results %}
            {% set label_text = item.label %}
            {% if td is not same as(false) %}
                {% if td is null %}
                    {% set label_text = item.label|trans %}
                {% else %}
                    {% set label_text = item.label|trans({}, td) %}
                {% endif %}
            {% endif %}

            <div class="autocomplete-option flex cursor-pointer flex-col items-center rounded-lg border border-gray-100 bg-white p-3 text-center transition-all hover:border-gray-300 hover:shadow-sm"
                 role="option"
                 tabindex="-1"
                 data-autocomplete-option-value="{{ item.id|e('html_attr') }}"
                 data-autocomplete-option-label="{{ label_text|e('html_attr') }}"
                 {% if item.meta is defined %}
                     data-autocomplete-option-meta="{{ item.meta|json_encode|e('html_attr') }}"
                 {% endif %}
            >
                {% if item.meta is defined and item.meta and item.meta.avatar is defined %}
                    <img class="mb-2 h-10 w-10 rounded-full object-cover"
                         src="{{ item.meta.avatar }}"
                         alt=""
                         loading="lazy">
                {% endif %}

                <p class="w-full truncate text-sm font-medium text-gray-900">{{ label_text }}</p>

                {% if item.meta is defined and item.meta %}
                    {% if item.meta.email is defined %}
                        <p class="w-full truncate text-xs text-gray-500">{{ item.meta.email }}</p>
                    {% endif %}
                    {% if item.meta.role is defined %}
                        <span class="mt-1 inline-block rounded-full bg-gray-100 px-2 py-0.5 text-xs text-gray-600">{{ item.meta.role }}</span>
                    {% endif %}
                {% endif %}
            </div>
        {% endfor %}
    </div>
{% endif %}
