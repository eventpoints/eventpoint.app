{% extends 'base.html.twig' %}

{% block body %}
<div class="mx-auto max-w-5xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-start">

        {# --- Profile card --- #}
        <div class="w-full shrink-0 lg:w-72">
            <div class="overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-gray-100">

                {# Avatar + name #}
                <div class="px-6 pb-6 pt-8 text-center">
                    <div class="relative mx-auto mb-4 h-24 w-24">
                        <img src="{{ user_avatar(user) }}"
                             class="h-24 w-24 rounded-full object-cover shadow-md ring-4 ring-white"
                             alt="{{ user.fullName }}">
                        <span class="absolute bottom-0.5 right-0.5 block h-4 w-4 rounded-full border-2 border-white bg-green-400"></span>
                    </div>
                    <h1 class="text-xl font-semibold text-gray-900">{{ user.fullName }}</h1>
                    <p class="mt-1 flex items-center justify-center gap-1 text-sm text-gray-500">
                        {{ ux_icon('mdi:calendar-outline', {class: 'h-4 w-4 shrink-0'}) }}
                        {{ user.createdAt|format_date }}
                    </p>
                </div>

                {# Actions #}
                {% if app.user and app.user.id != user.id %}
                    <div class="border-t border-gray-100">
                        <a href="{{ path('create_direct_conversation', {id: user.id}) }}"
                           class="flex items-center justify-between px-5 py-4 text-sm font-medium text-gray-700 no-underline transition-colors hover:bg-gray-50">
                            <span>{{ 'send-message'|trans }}</span>
                            {{ ux_icon('mdi:message-outline', {class: 'h-5 w-5 text-gray-400'}) }}
                        </a>
                    </div>
                {% endif %}

            </div>
        </div>

        {# --- Activity panel --- #}
        <div class="flex flex-1 flex-col gap-6">

            <div class="overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-gray-100">
                <div class="flex items-center justify-between border-b border-gray-100 px-5 py-4">
                    <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-400">{{ 'event-activity'|trans }}</h2>
                </div>
                <div class="px-5 py-5">
                    <canvas style="height: 160px; width: 100%;"
                            {{ stimulus_controller('event-activity-chart', {
                                events: userEventActivity|json_encode
                            }) }}></canvas>
                </div>
            </div>

        </div>

    </div>
</div>
{% endblock %}
